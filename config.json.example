{
  "web_port": 8889,
  "static_dir": "./static/browser",
  "setup_complete": false,
  "database": {
    "host": "localhost",
    "port": 5432,
    "name": "colada_scale",
    "user": "colada_user",
    "password": "your_password_here"
  },
  "mqtt": {
    "enabled": true,
    "broker": "localhost",
    "port": 1883,
    "username": "mqtt_user",
