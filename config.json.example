    "client_id": "hms_colada",
    "scale_topic": "giraffe_scale/measurement",
    "user_selector_topic": "colada_scale/user_selector/set"
  },
  "ml_training": {
    "enabled": false,
    "schedule": "weekly",
    "model_dir": "",
    "min_measurements": 20
  }
}
